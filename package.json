{
  "name": "edumanager-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=@edumanager/backend",
    "dev:frontend": "npm run start --workspace=@edumanager/frontend",
    "build:shared": "npm run build --workspace=@edumanager/shared",
    "build:backend": "npm run build --workspace=@edumanager/backend",
    "build:frontend": "npm run build --workspace=@edumanager/frontend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test:backend": "npm run test --workspace=@edumanager/backend"
  }
}
